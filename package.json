{
  "name": "openwrt-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "bun run build && scp -r dist/* root@10.10.0.1:/www/ && ssh root@10.10.0.1 \"uci -q get uhttpd.main.error_page | grep -q index.html || (uci set uhttpd.main.error_page=/index.html && uci commit uhttpd && /etc/init.d/uhttpd reload)\""
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@tsconfig/svelte": "^5.0.8",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  },
  "dependencies": {
    "@lucide/svelte": "^1.21.0",
    "@melt-ui/svelte": "^0.86.6",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1"
  }
}
